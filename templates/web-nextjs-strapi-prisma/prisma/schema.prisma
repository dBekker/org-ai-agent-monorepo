generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  userId     String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
